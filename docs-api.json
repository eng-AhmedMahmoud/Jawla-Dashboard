  "info": {
    "title": "Jawla Tours API",
    "description": "The Jawla Tours API description",
    "version": "1.0",
    "contact": {

    }
  },
  "tags": [
    {
      "name": "jawla",
      "description": ""
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "User email address"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "description": "User password (min 6 characters)"
          },
          "confirmPassword": {
            "type": "string",
            "example": "password123",
            "description": "Confirm password matching the password field"
          },
          "name": {
            "type": "string",
            "example": "John Doe",
            "description": "Full name of the user"
          }
        },
        "required": [
          "email",
          "password",
          "confirmPassword",
          "name"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR...",
            "description": "JWT Access Token"
          },
          "user": {
            "type": "object",
            "example": {
              "id": "123e4567-e89b-12d3-a456-426614174000",
              "email": "user@example.com",
              "name": "John Doe",
              "role": "USER"
            },
            "description": "User details"
          }
        },
        "required": [
          "access_token",
          "user"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "User email address"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "description": "User password"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "ForgotPasswordDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "User email address to send reset link"
          }
        },
        "required": [
          "email"
        ]
      },
      "ResetPasswordDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "example": "reset-token-123",
            "description": "Password reset token received via email"
          },
          "newPassword": {
            "type": "string",
            "example": "newPassword123",
            "description": "New password (min 6 characters)"
          },
          "confirmNewPassword": {
            "type": "string",
            "example": "newPassword123",
            "description": "Confirm new password"
          }
        },
        "required": [
          "token",
          "newPassword",
          "confirmNewPassword"
        ]
      },
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "role": {
            "type": "string",
            "enum": [
              "ADMIN",
              "USER"
            ]
          },
          "phone": {
            "type": "string",
            "example": "0123456789"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "email",
          "name",
          "role",
          "phone",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe",
            "description": "Full name"
          },
          "password": {
            "type": "string",
            "example": "newpassword123",
            "description": "New password"
          },
          "phone": {
            "type": "string",
            "example": "01000000000",
            "description": "Phone number"
          }
        }
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "User email address"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "description": "User password (min 6 characters)"
          },
          "name": {
            "type": "string",
            "example": "John Doe",
            "description": "Full name of the user"
          },
          "role": {
            "type": "string",
            "enum": [
              "ADMIN",
              "USER"
            ],
            "default": "USER",
            "description": "User role"
          },
          "phone": {
            "type": "string",
            "example": "0123456789",
            "description": "User phone number"
          }
        },
        "required": [
          "email",
          "password",
          "name",
          "role",
          "phone"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "User email address"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "description": "User password (min 6 characters)"
          },
          "name": {
            "type": "string",
            "example": "John Doe",
            "description": "Full name of the user"
          },
          "role": {
            "type": "string",
            "enum": [
              "ADMIN",
              "USER"
            ],
            "default": "USER",
            "description": "User role"
          },
          "phone": {
            "type": "string",
            "example": "0123456789",
            "description": "User phone number"
          }
        }
      },
      "CreatePackageDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Saudi Arabia Trips",
            "description": "Title of the package"
          },
          "description": {
            "type": "string",
            "example": "Experience the magic of Arabia...",
            "description": "Detailed description"
          },
          "price": {
            "type": "number",
            "example": 27800,
            "description": "Price of the package"
          },
          "currency": {
            "type": "string",
            "example": "EGP",
            "description": "Currency code"
          },
          "duration": {
            "type": "string",
            "example": "10 Days",
            "description": "Duration of the package"
          },
          "image": {
            "type": "string",
            "example": "https://example.com/image.jpg",
            "description": "Cover image URL"
          },
          "isFeatured": {
            "type": "boolean",
            "example": true,
            "description": "Show on homepage?"
          },
          "includedServices": {
            "example": [
              "Flight",
              "Hotel",
              "Visa"
            ],
            "description": "List of included services",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "title",
          "description",
          "price",
          "duration",
          "image",
          "includedServices"
        ]
      },
      "UpdatePackageDto": {
        "type": "object",
